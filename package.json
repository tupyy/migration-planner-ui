{
  "name": "migration-planner-ui",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:all": "yarn workspaces foreach -t --all run build",
    "bundle:all": "yarn workspaces foreach -t --all run bundle",
    "clean:all": "rm -rf out && yarn workspaces foreach --all -p run clean",
    "check:all": "yarn workspaces foreach --all -p run check",
    "check:fix:all": "yarn workspaces foreach --all -p run check:fix",
    "test:all": "yarn workspaces foreach --all -p run test",
    "typecheck:all": "yarn workspaces foreach --all -p run typecheck",
    "update:api-client": "make api-client"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/node": "^25.8.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "~4.3.1",
    "typescript": "~6.0.3",
    "vite": "~8.0.13"
  },
  "resolutions": {
    "glob": "^13.0.6",
    "minimatch": "^10.2.2"
  },
  "packageManager": "yarn@4.14.1"
}
